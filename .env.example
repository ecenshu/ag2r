# AG2R Configuration
# Copy this file to .env and edit as needed.
# See README.md for setup instructions.

# ─── Server ───────────────────────────────────
PORT=3000

# ─── Remote Access ────────────────────────────
# Uncomment these to enable authentication and tunneling.
# Required when exposing AG2R to the internet.
#
# AUTH_ENABLED=true
# APP_PASSWORD=your-strong-password-here
# SESSION_SECRET=<run: openssl rand -hex 32>
# TUNNEL_ENABLED=true
# TUNNEL_URL=https://your-tunnel-url.com
